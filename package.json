{
  "name": "yomusic-app",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "start pnpm run dev & start pnpm run dev:android",
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "format": "prettier --write .",
    "dev:android": "npx cap run android -l --host=localhost --port=5173",
    "build:android": "pnpm run build && npx cap sync",
    "lint": "eslint .",
    "preview": "vite preview",
    "assembleDebug": "pnpm run build:android && cd android && gradlew.bat assembleDebug && cd ../",
    "assembleRelease": "pnpm run build:android && npx cap build android",
    "installApp": "pnpm run assembleDebug &&  adb install -r android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capacitor/toast": "8.0.0",
    "@capawesome/capacitor-android-edge-to-edge-support": "^8.0.8",
    "@tailwindcss/vite": "^4.3.0",
    "capacitor-music-controls-plugin": "6.1.0",
    "embla-carousel-react": "8.6.0",
    "konsta": "5.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0",
    "zod": "4.3.6",
    "zustand": "5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
